# Kopieer dit bestand naar .env.local en vul je Supabase-gegevens in
# Vind deze in: Supabase Dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://jouw-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=jouw-anon-public-key

# Voor klantuitnodigingen is geen service-role key in de frontend nodig.
# De activatiemail loopt via de publieke Supabase auth-flow.

# URL van de FastAPI backend (lokaal of Railway)
NEXT_PUBLIC_API_URL=http://localhost:8000
