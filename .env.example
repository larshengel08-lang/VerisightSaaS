# Verisight — FastAPI backend omgevingsvariabelen
# Kopieer naar .env en vul in

# Supabase PostgreSQL connectiestring (Session mode, port 5432)
# Vind in: Supabase → Project Settings → Database → URI
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Supabase service-role key (voor bypassen RLS bij survey-submissions)
# Vind in: Supabase → Project Settings → API → service_role (geheim!)
SUPABASE_SERVICE_ROLE_KEY=jouw-service-role-key
SUPABASE_URL=https://jouw-project-id.supabase.co

# OpenAI — UITGESCHAKELD (AVG: EU-werknemersdata mag niet zonder expliciete
# toestemming naar een Amerikaanse verwerker). Vul pas in na juridische goedkeuring.
# OPENAI_API_KEY=sk-jouw-sleutel-hier

# URL van de Next.js frontend (voor CORS)
FRONTEND_URL=http://localhost:3000
ADDITIONAL_CORS_ORIGINS=

# URL van de FastAPI backend (voor survey-links in e-mails)
BACKEND_URL=http://localhost:8000

# Resend e-mailconfiguratie
RESEND_API_KEY=re_jouw_resend_api_key
EMAIL_FROM=Verisight <noreply@verisight.nl>

# Inboxadres voor kennismakingsaanvragen vanaf de marketing-site
CONTACT_EMAIL=hallo@verisight.nl

# Sentry error monitoring (gratis tier: sentry.io)
# Vind in: Sentry → Project → Settings → Client Keys (DSN)
SENTRY_DSN=https://jouw-sentry-dsn@sentry.io/project-id

# Interne server-token voor vertrouwde frontend-proxy's, zoals PDF-download.
BACKEND_ADMIN_TOKEN=jouw-backend-admin-token

ENVIRONMENT=production
